# Sleipnir environment configuration (example).
# Copy to .env and fill in real values. NEVER commit a real .env.

# --- Exchange backend ---
# "binance" (default, live testnet) or "sim" (in-memory, no credentials).
EXCHANGE_BACKEND=sim

# Required only when EXCHANGE_BACKEND=binance.
BINANCE_API_KEY=your-binance-api-key
BINANCE_API_SECRET=your-binance-api-secret

# --- Control-plane auth ---
# Bearer token gating the mutating admin endpoints (/admin/halt POST,
# /admin/resume). These FAIL CLOSED: if this is unset the kill-switch
# mutations are rejected with 503. Must be set for the operator kill switch
# to work. Use a long random value in real deployments.
SLEIPNIR_ADMIN_TOKEN=localdev-change-me

# --- Kafka ---
KAFKA_BROKERS=localhost:9092
KAFKA_INTENTS_TOPIC=executions.intents.v1
KAFKA_FILLS_TOPIC=executions.fills.v1
KAFKA_CONSUMER_GROUP=sleipnir-gateway

# --- HTTP / storage ---
PORT=8080
DB_PATH=/app/data/sleipnir.db
